{
  "name": "@wpbones/wpkirk-nuxtjs",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "serve": "nuxi preview",
    "clean": "nuxi cleanup && rm -rf .output",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:style": "stylelint 'resources/**/*.{css,scss}'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "make-pot": "wp i18n make-pot . languages/wp-kirk.pot --slug=wp-kirk --domain=wp-kirk --exclude=node_modules,resources/assets",
    "make-json": "wp i18n make-json languages/ --no-purge"
  },
  "license": "GPL-3.0",
  "author": "Giovambattista Fazioli <wpbones.info@gmail.com>",
  "devDependencies": {
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^25.0.0",
    "nuxt": "^3.15.0",
    "sass": "^1.83.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "dependencies": {
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@headlessui/tailwindcss": "^0.2.2",
    "@nuxt/ui": "2.12.1"
  }
}
